{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "bucket": "mushey-real-estate.firebasestorage.app",
    "rules": "storage.rules"
  },
  "functions": {
    "source": "functions"
  }
}
